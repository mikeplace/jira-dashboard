# Team Performance Dashboard Configuration
# Copy this file to .env and fill in your values

# Jira Configuration (Required)
JIRA_URL=https://atlasergonomics.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=AEB

# Slack Configuration (Required for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# Slack Bot Configuration (Required for standup analysis)
# Create a Slack app at https://api.slack.com/apps with these scopes:
#   - channels:history (read messages)
#   - users:read (get user names)
# Then add the bot to #ongoing-sprint-work channel
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_STANDUP_CHANNEL=ongoing-sprint-work
SLACK_STANDUP_CHANNEL_ID=C0XXXXXXXXX

# GitHub Configuration (Optional - set to true to enable)
GITHUB_ENABLED=false
GITHUB_TOKEN=your-github-token
GITHUB_ORG=voidsstr
GITHUB_REPO=AtlasErgoBackend

# Metrics Configuration
STALE_THRESHOLD_DAYS=3
LOOKBACK_DAYS=30

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000

# Database path (relative or absolute)
DATABASE_PATH=team_metrics.db
